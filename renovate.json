{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": ["flux"],
  "flux": {
    "managerFilePatterns": [
      "/(^|/)clusters/.+\\.ya?ml$/",
      "/(^|/)infrastructure/.+\\.ya?ml$/",
      "/(^|/)apps/.+\\.ya?ml$/"
    ]
  },
  "schedule": ["every weekend"]
}
